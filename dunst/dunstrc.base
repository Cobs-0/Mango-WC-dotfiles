[global]
corner_radius=10
font="JetBrainsMono Nerd Font 10"
force_xwayland=no
format="<b>%s</b>\n%b"
frame_width=2
gap_size=5
height=(0,300)
icon_position="left"
layer="overlay"
max_icon_size=64
offset=(20,20)
origin="top-right"
width=(0,400)
word_wrap = yes
padding = 15
horizontal_padding = 15

[urgency_critical]
timeout=0
[urgency_low]
timeout=5
[urgency_normal]
timeout=8
